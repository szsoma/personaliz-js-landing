---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/layout/SEO.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import VSL from '../components/sections/VSL.astro';
import CTABand from '../components/sections/CTABand.astro';
import SocialProof from '../components/sections/SocialProof.astro';
import Benefits from '../components/sections/Benefits.astro';
import BeforeAfter from '../components/sections/BeforeAfter.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import WhatsIncluded from '../components/sections/WhatsIncluded.astro';
import CTA from '../components/sections/CTA.astro';
import AboutUs from '../components/sections/AboutUs.astro';
import Trust from '../components/sections/Trust.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import SubscribePopup from '../components/interactive/SubscribePopup.svelte';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SEO />
  <script is:inline>
    const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'stripe-dark' : 'stripe-light');
    document.documentElement.setAttribute('data-theme', theme);
  </script>
</head>
<body>
  <Navbar />
  <main>
    <Hero />
    <Problem />
    <VSL />
    <CTABand />
    <SocialProof />
    <Benefits />
    <BeforeAfter />
    <HowItWorks />
    <WhatsIncluded />
    <CTA />
    <AboutUs />
    <Trust />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <SubscribePopup client:load />
</body>
</html>
