---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import VSL from '../components/sections/VSL.astro';
import CTABand from '../components/sections/CTABand.astro';
import SocialProof from '../components/sections/SocialProof.astro';
import Benefits from '../components/sections/Benefits.astro';
import BeforeAfter from '../components/sections/BeforeAfter.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import WhatsIncluded from '../components/sections/WhatsIncluded.astro';
import CTA from '../components/sections/CTA.astro';
import AboutUs from '../components/sections/AboutUs.astro';
import Trust from '../components/sections/Trust.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import SubscribePopup from '../components/interactive/SubscribePopup.svelte';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script is:inline>
    const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'stripe-dark' : 'stripe-light');
    document.documentElement.setAttribute('data-theme', theme);
  </script>
  <title>PersonalizeJS — Turn one page into many campaign-specific landing pages</title>
  <meta name="description" content="Change headlines, subtitles, CTAs, links, and sections based on URL parameters, UTMs, referrer, returning visitors, location, time, or past behavior. No duplicate pages. No backend.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.0.0/dist/fonts/geist-sans/style.css">
</head>
<body>
  <Navbar />
  <main>
    <Hero />
    <Problem />
    <VSL />
    <CTABand />
    <SocialProof />
    <Benefits />
    <BeforeAfter />
    <HowItWorks />
    <WhatsIncluded />
    <CTA />
    <AboutUs />
    <Trust />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <SubscribePopup client:load />
</body>
</html>
