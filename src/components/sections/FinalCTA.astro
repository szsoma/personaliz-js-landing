---
// src/components/sections/FinalCTA.astro
---

<section class="py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-neutral via-neutral to-primary/20"></div>
  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-neutral-content text-3xl md:text-4xl font-light leading-tight tracking-tight mb-4">
      Stop sending specific ads to generic landing pages
    </h2>
    <p class="text-neutral-content/60 text-base md:text-lg mb-8">
      Personalize landing pages from campaign URLs, UTMs, visitor behavior, and more.
    </p>
    <div class="flex flex-wrap justify-center gap-4 mb-6">
      <a href="#subscribe" class="btn btn-primary btn-lg">Get early access</a>
      <a href="#how-it-works" class="btn btn-ghost btn-lg border-white/20 text-neutral-content hover:bg-white/10">See setup example</a>
    </div>
    <p class="text-neutral-content/40 text-sm">
      Built for marketing sites and PPC campaign teams.
    </p>
  </div>
</section>
