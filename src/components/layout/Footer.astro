---
// src/components/layout/Footer.astro
---
<footer class="bg-neutral text-neutral-content py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center">
        <img src="/logo.svg" class="max-w-[100px] h-auto logo-light" alt="ShiftyJS" width="430" height="112" />
      </div>
      <p class="text-sm opacity-60">Built for marketers who move faster than their website process.</p>
      <p class="text-sm opacity-60">&copy; {new Date().getFullYear()} ShiftyJS. All rights reserved.</p>
    </div>
  </div>
</footer>
