---
// src/components/layout/Footer.astro
---
<footer class="bg-neutral text-neutral-content py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center">
        <img src="/logo.svg" class="max-w-[100px] h-auto logo-light" alt="ShiftyJS" width="430" height="112" />
      </div>
      <div class="flex gap-6 text-sm opacity-60">
        <a href="/blog" class="hover:opacity-100 transition-opacity">Blog</a>
        <a href="/use-cases/google-ads" class="hover:opacity-100 transition-opacity">Google Ads</a>
        <a href="/use-cases/linkedin-ads" class="hover:opacity-100 transition-opacity">LinkedIn Ads</a>
      </div>
      <p class="text-sm opacity-60">&copy; {new Date().getFullYear()} ShiftyJS. All rights reserved.</p>
    </div>
  </div>
</footer>
