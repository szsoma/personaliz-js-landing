---
// src/components/layout/Navbar.astro
---
<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-base-100/95 backdrop-blur-md" id="navbar">
  <div class="mx-auto max-w-6xl px-6">
    <div class="navbar px-0">
      <div class="navbar-start">
        <a href="/" class="flex items-center">
          <img src="/logo.svg" class="max-w-[100px] h-auto logo-img" alt="ShiftyJS" width="430" height="112" />
        </a>
      </div>
      <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal gap-1">
          <li><a href="/#features" class="text-sm text-base-content/70 hover:text-base-content active:text-primary-content active:bg-primary">Features</a></li>
          <li><a href="/#how-it-works" class="text-sm text-base-content/70 hover:text-base-content active:text-primary-content active:bg-primary">How It Works</a></li>
          <li><a href="/blog" class="text-sm text-base-content/70 hover:text-base-content active:text-primary-content active:bg-primary">Blog</a></li>
          <li><a href="/#faq" class="text-sm text-base-content/70 hover:text-base-content active:text-primary-content active:bg-primary">FAQ</a></li>
        </ul>
      </div>
      <div class="navbar-end gap-2">
        <button onclick="window.openSubscribePopup?.()" class="btn btn-primary btn-sm">
          Get early access
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 20) {
      navbar.classList.add('shadow-sm');
    } else {
      navbar.classList.remove('shadow-sm');
    }
    lastScroll = currentScroll;
  });
</script>
